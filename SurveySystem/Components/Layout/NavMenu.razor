<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">SurveySystem</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">

        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3 mt-3 mb-3">
                    <div class="p-3 rounded" style="background-color: rgba(255, 255, 255, 0.08); border: 1px solid rgba(255, 255, 255, 0.1);">
                        <span class="d-block text-white-50" style="font-size: 0.85rem;">Witaj!</span>
                        <span class="d-block text-white fw-bold text-truncate mt-1" title="@context.User.Identity?.Name">
                            @context.User.Identity?.Name
                        </span>
                    </div>
                </div>
            </Authorized>
        </AuthorizeView>
        
        <AuthorizeView Roles="Ankieter">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link d-flex align-items-center" href="create-survey">
                        <span class="bi bi-plus-square fs-4 me-3" aria-hidden="true" style="line-height: 1;"></span>
                        <span class="mt-1">Kreator Ankiety</span>
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link d-flex align-items-center" href="surveys">
                        <span class="bi bi-list-check fs-4 me-3" aria-hidden="true" style="line-height: 1;"></span>
                        <span class="mt-1">Lista Ankiet</span>
                    </NavLink>
                </div>
                
                <div class="nav-item px-3 mt-4">
                    <form action="/Account/Logout" method="post">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="Account/Login" />
                        <button type="submit" class="nav-link d-flex align-items-center w-100 btn btn-link text-danger border-0 text-start">
                            <span class="bi bi-box-arrow-right fs-4 me-3" aria-hidden="true" style="line-height: 1;"></span>
                            <span class="mt-1">Wyloguj</span>
                        </button>
                    </form>
                </div>
            </Authorized>
            
            <NotAuthorized>
                <div class="nav-item px-3 mt-3">
                    <NavLink class="nav-link d-flex align-items-center" href="Account/Login">
                        <span class="bi bi-person-badge fs-4 me-3" aria-hidden="true" style="line-height: 1;"></span>
                        <span class="mt-1">Zaloguj się</span>
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link d-flex align-items-center" href="Account/Register">
                        <span class="bi bi-person-plus fs-4 me-3" aria-hidden="true" style="line-height: 1;"></span>
                        <span class="mt-1">Rejestracja</span>
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>

    </nav>
</div>