@page "/surveys"
@using SurveySystem.Services
@using SurveySystem.Models
@inject SurveyService SurveyService

<PageTitle>Dostępne Ankiety</PageTitle>

<div class="container mt-4">
    <h2 class="text-primary mb-4">Wybierz ankietę do wypełnienia</h2>

    @if (surveys == null)
    {
        <p><em>Ładowanie listy ankiet...</em></p>
    }
    else if (!surveys.Any())
    {
        <div class="alert alert-warning">Brak dostępnych ankiet. Stwórz pierwszą w kreatorze!</div>
    }
    else
    {
       <div class="list-group" style="max-width: 700px;">
            @foreach (var survey in surveys)
            {
                <div class="list-group-item d-flex justify-content-between align-items-center mb-2 shadow-sm rounded p-3">
                    <span class="fw-bold fs-5">@survey.Title</span>
                    
                    <div>
                        <a href="/survey/@survey.Id/results" class="btn btn-outline-info me-2">
                            <i class="bi bi-bar-chart-fill"></i> Wyniki
                        </a>
                        <a href="/survey/@survey.Id" class="btn btn-success">
                            <i class="bi bi-check-circle"></i> Zagłosuj
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Survey>? surveys;

    protected override async Task OnInitializedAsync()
    {
        surveys = await SurveyService.GetAllSurveysAsync();
    }
}