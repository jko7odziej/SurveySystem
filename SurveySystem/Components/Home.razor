@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@layout SurveySystem.Components.Layout.EmptyLayout

<PageTitle>Strona Główna - SurveySystem</PageTitle>

<div class="container mt-5 text-center">
    <h1 class="display-4 text-primary fw-bold mb-3">Witamy w systemie ankiet!</h1>
    
    <AuthorizeView>
        <NotAuthorized>
            <p class="lead mb-5 text-muted">Aby odkryć pełne możliwości, zaloguj się lub załóż nowe konto.</p>
            
            <div class="row justify-content-center">
                <div class="col-md-4 mb-3">
                    <div class="card shadow-sm h-100 border-primary">
                        <div class="card-body p-5 d-flex flex-column justify-content-center">
                            <i class="bi bi-person-badge fs-1 text-primary mb-3"></i>
                            <h3>Mam już konto</h3>
                            <p class="text-muted mb-4">Zaloguj się, aby oddać głos i zobaczyć wyniki.</p>
                            <a href="/Account/Login" class="btn btn-primary btn-lg mt-auto">Zaloguj się</a>
                        </div>
                    </div>
                </div>
                
                <div class="col-md-4 mb-3">
                    <div class="card shadow-sm h-100 border-success">
                        <div class="card-body p-5 d-flex flex-column justify-content-center">
                            <i class="bi bi-person-plus fs-1 text-success mb-3"></i>
                            <h3>Jestem tu nowy</h3>
                            <p class="text-muted mb-4">Załóż darmowe konto i dołącz do głosowania.</p>
                            <a href="/Account/Register" class="btn btn-success btn-lg mt-auto">Zarejestruj się</a>
                        </div>
                    </div>
                </div>
            </div>
        </NotAuthorized>

        <Authorized>
            <p class="lead mb-5">Jesteś zalogowany jako <strong>@context.User.Identity?.Name</strong>. Co chcesz teraz zrobić?</p>
            
            <div class="row justify-content-center gap-4">
                <div class="col-md-4">
                    <a href="/surveys" class="btn btn-outline-primary btn-lg w-100 p-4 shadow-sm">
                        <i class="bi bi-list-check d-block mb-2 fs-1"></i>
                        Przejdź do Listy Ankiet
                    </a>
                </div>
                
                @if (context.User.IsInRole("Ankieter"))
                {
                    <div class="col-md-4">
                        <a href="/create-survey" class="btn btn-outline-success btn-lg w-100 p-4 shadow-sm">
                            <i class="bi bi-plus-square d-block mb-2 fs-1"></i>
                            Stwórz nową ankietę
                        </a>
                    </div>
                }
            </div>
        </Authorized>
    </AuthorizeView>
</div>